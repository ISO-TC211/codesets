:placeholder
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "placeholder concept" ;
    skos:historyNote "to be removed when codelist is under active management"@en ;
    skos:inScheme cs: ;
    skos:prefLabel "placeholder"@en ;
    skos:topConceptOf cs: ;
