.

cs:
    a skos:ConceptScheme ;
    skos:definition "AddressPosition represents information about the representative position of an address"@en ;
    skos:hasTopConcept :placeholder ;
    skos:historyNote "This code set was extracted directly from the defining standard: ISO19160-1:2015"@en ;
    skos:prefLabel "Address Position Type"@en ;
    skos:scopeNote "This codelist has no values provided in the specifying standard. It may be added to through standard TC-211 codelist extension practices"@en ;
    schema:citation "http://standards.iso.org/iso/19160/-1/ed-1/en/"^^xsd:anyURI ;
    schema:contributor <https://def.isotc211.org/org/ogc> ;
    schema:creator <https://def.isotc211.org/org/tc211> ;
    schema:dateCreated "2015-12-15"^^xsd:date ;
    schema:dateIssued "2025-11-19"^^xsd:date ;
    schema:dateModified "2025-08-01"^^xsd:date ;
    schema:isPartOf <https://def.isotc211.org/codesets> ;
    schema:publisher <https://def.isotc211.org/org/tc211> ;
    schema:status status:experimental ;
.
