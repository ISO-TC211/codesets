PREFIX : <https://def.isotc211.org/common/DecisionStatus/>
PREFIX cs: <https://def.isotc211.org/common/DecisionStatus>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX status: <https://def.isotc211.org/common/ItemStatus/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

:final
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A decision has been made and the time limit for appeal has run out or an appeal has been resolved"@en ;
    skos:historyNote "From page 49, ISO19135-1:2014"@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Final"@en ;
    schema:status status:original ;
.

:pending
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "No decision has been made"@en ;
    skos:historyNote "From page 49, ISO19135-1:2014"@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Pending"@en ;
    schema:status status:original ;
.

:tentative
    a skos:Concept ;
    rdfs:isDefinedBy cs: ;
    skos:definition "A decision has been made, but it is still subject to appeal"@en ;
    skos:historyNote "From page 49, ISO19135-1:2014"@en ;
    skos:inScheme cs: ;
    skos:prefLabel "Tentative"@en ;
    schema:status status:original ;
.

cs:
    a skos:ConceptScheme ;
    rdfs:isDefinedBy <https://def.isotc211.org/common/standards/iso-19135-1-2015> ;
    skos:definition "Instances of RE_DecisionStatus that identify the standing of the proposed change within the approval process"@en ;
    skos:hasTopConcept
        :final ,
        :pending ,
        :tentative ;
    skos:historyNote "Created manually by GOM staff directly from the ISO19135-1:2014 document"@en ;
    skos:prefLabel "RE Decision Status Codes"@en ;
    schema:citation "http://standards.iso.org/iso/19135/-1/ed-1/en/"^^xsd:anyURI ;
    schema:creator <https://def.isotc211.org/org/tc211> ;
    schema:dateCreated "2014-09-18"^^xsd:date ;
    schema:dateModified "2025-08-01"^^xsd:date ;
    schema:isPartOf <https://def.isotc211.org/codesets> ;
    schema:publisher <https://def.isotc211.org/org/tc211> ;
    schema:status status:stable ;
.
